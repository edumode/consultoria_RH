# Supabase — copia este archivo a .env.local y rellena con los valores
# de tu proyecto: Supabase Dashboard > Project Settings > API.

# URL del proyecto (p. ej. https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública anon (anon / public). Segura para el navegador.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave secreta service_role — SOLO servidor, nunca con prefijo NEXT_PUBLIC.
# Necesaria para el cron que publica/envía entradas programadas.
SUPABASE_SERVICE_ROLE_KEY=

# URL pública del sitio (para enlaces absolutos en los correos). En local:
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — envío de la newsletter. https://resend.com (API Keys + dominio verificado)
RESEND_API_KEY=
# Remitente verificado, p. ej. "VÉRTICE <newsletter@tudominio.com>"
RESEND_FROM=

# Secreto para proteger el endpoint /api/cron/publicar. Genera uno aleatorio.
CRON_SECRET=
